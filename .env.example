# RAG系统配置文件示例
# 复制此文件为 .env 并填入实际值

# ========== LLM API配置 ==========
# OpenRouter API密钥 (必需)
RAG_API_KEY=your_openrouter_api_key_here

# ========== 知识库配置 ==========
# 数据目录路径
DATA_PATH=./data

# 向量索引保存路径 (仅FAISS使用)
INDEX_SAVE_PATH=./vector_index

# ========== 向量数据库配置 ==========
# 向量数据库类型: faiss 或 milvus
VECTOR_DB_TYPE=milvus

# Milvus配置
MILVUS_URI=http://localhost:19530
MILVUS_DATABASE=rag_db

# ========== 模型配置 ==========
# 嵌入模型名称
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# LLM模型名称
LLM_MODEL=qwen/qwen3.5-flash-02-23

# ========== 检索配置 ==========
# 检索返回的文档数量
TOP_K=3

# ========== 生成配置 ==========
# 生成温度
TEMPERATURE=0.1

# 最大生成token数
MAX_TOKENS=2048

# ========== API服务器配置 ==========
# 服务器监听地址 (0.0.0.0表示所有接口)
SERVER_HOST=0.0.0.0

# 服务器监听端口
SERVER_PORT=8000

# API服务器访问密钥 (留空则不需要认证)
SERVER_API_KEY=your_server_api_key_here
